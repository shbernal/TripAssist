{
  "name": "@tripassist/demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TripAssist - stylized animated story landing page (static, → GitHub Pages)",
  "comment": "Scripts call `node node_modules/<pkg>/...` directly, never npx/pnpm-exec, matching the root package: the repo path can contain a ':' that corrupts the .bin PATH shim.",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "typecheck": "node node_modules/typescript/bin/tsc -p tsconfig.json --noEmit && node node_modules/typescript/bin/tsc -p tsconfig.node.json --noEmit",
    "lint": "node node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node node_modules/eslint/bin/eslint.js . --fix"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "gsap": "^3.12.0",
    "howler": "^2.2.4",
    "lenis": "^1.1.0",
    "lottie-react": "^2.4.0",
    "lucide-react": "^1.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wavesurfer.js": "^7.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/howler": "^2.2.11",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "lighthouse": "^13.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.0"
  }
}
