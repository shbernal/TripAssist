# TripAssist environment — copy to .env and fill in (M3+ needs the Vapi keys).
ANTHROPIC_API_KEY=
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
RECEPTIONIST_PHONE=
SNCF_API_KEY=
PUBLIC_URL=
# Navitia (free token at navitia.io) for real Paris→Nice journeys + live disruptions
NAVITIA_TOKEN=
NAVITIA_BASE_URL=https://api.navitia.io
NAVITIA_COVERAGE=sncf
PORT=3000
# SQLite store path for the MVP (server/store.ts). Optional — defaults to
# data/accesstrip.db. Use ':memory:' for an ephemeral, disk-free store.
ACCESSTRIP_DB=./data/accesstrip.db
# Secret used to sign operator session cookies (server/auth.ts). Optional in dev —
# a stable default is used when unset; set a real value for any shared/deployed instance.
SESSION_SECRET=
# Itinerary ingestion (server/ingest.ts) reuses ANTHROPIC_API_KEY above; with no key it
# falls back to a deterministic offline parse.

# ElevenLabs — voice generation for the demo landing page (apps/demo).
# Only needed to (re)generate call audio via tooling/demo/generate-voices.ts.
# The three voice IDs are optional: scripts carry public-voice fallbacks, so
# ELEVENLABS_API_KEY alone is enough.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_AGENT=
ELEVENLABS_VOICE_AIRPORT=
ELEVENLABS_VOICE_HOTEL=
