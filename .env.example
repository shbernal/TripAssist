# TripAssist (demo showcase branch) — copy to .env and fill in.
#
# The two shipped apps (apps/demo, apps/dashboard) are fully static and run with
# ZERO keys: all generated media is committed. Keys are only needed to REGENERATE
# the landing page's call audio via tooling/demo/generate-voices.ts.
#
# (The functional MVP and its ANTHROPIC_*/VAPI_* keys live on the `mvp` branch.)

# ElevenLabs — voice generation for the demo landing page (apps/demo).
# The three voice IDs are optional: the scripts carry public-voice fallbacks, so
# ELEVENLABS_API_KEY alone is enough.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_AGENT=
ELEVENLABS_VOICE_AIRPORT=
ELEVENLABS_VOICE_HOTEL=
