# TripAssist environment — copy to .env and fill in (M3+ needs the Vapi keys).
ANTHROPIC_API_KEY=
# Alternative to a direct key: an enterprise gateway / OAuth token (+ base URL),
# or the local `claude` CLI as a bridge to real Claude (planner/extractor/vision/
# ingest — vision passes the photo via a temp file the CLI reads itself).
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_VIA_CLI=
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
RECEPTIONIST_PHONE=
PUBLIC_URL=
# Navitia (free token at navitia.io) for real Paris→Nice journeys + live disruptions
NAVITIA_TOKEN=
NAVITIA_BASE_URL=https://api.navitia.io
NAVITIA_COVERAGE=sncf
# acceslibre (free token — register at acceslibre.beta.gouv.fr) for the live
# accessibility registry; without it a verified reference dataset is served.
ACCESLIBRE_TOKEN=
# OpenRouteService (free token at openrouteservice.org) for live wheelchair-profile
# routing; without it a reference route consistent with the profile is served.
ORS_TOKEN=
PORT=3000
# SQLite store path for the MVP (server/store.ts). Optional — defaults to
# data/tripassist.db. Use ':memory:' for an ephemeral, disk-free store.
TRIPASSIST_DB=./data/tripassist.db
# Secret used to sign operator session cookies (server/auth.ts). Optional in dev —
# a stable default is used when unset; set a real value for any shared/deployed instance.
SESSION_SECRET=
# Itinerary ingestion (server/ingest.ts) reuses ANTHROPIC_API_KEY above; with no key it
# falls back to a deterministic offline parse.
