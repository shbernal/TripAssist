{
  "name": "accesstrip",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AccessTrip — AI trip-orchestration for disabled travelers (hackathon demo)",
  "comment": "Scripts call `node <entrypoint>` directly instead of the .bin shim, because the parent folder name contains a ':' which corrupts PATH and breaks local binaries.",
  "scripts": {
    "dev": "node scripts/dev.js",
    "server": "node server/index.js",
    "web": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/vite/bin/vite.js build",
    "start": "node server/index.js",
    "smoke": "node scripts/smoke.js",
    "pw:install": "node node_modules/playwright/cli.js install chromium"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "playwright": "^1.61.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "vite": "^5.4.0"
  }
}
