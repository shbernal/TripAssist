{
  "name": "tripassist",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "description": "TripAssist - AI trip-orchestration for disabled travelers (hackathon demo)",
  "comment": "Scripts call `node <entrypoint>` directly instead of the .bin shim, because the parent folder name contains a ':' which corrupts PATH and breaks local binaries. All tooling (tsx, tsc, vite, eslint, prettier, lefthook) is invoked the same way.",
  "scripts": {
    "dev": "node node_modules/tsx/dist/cli.mjs scripts/dev.ts",
    "server": "node node_modules/tsx/dist/cli.mjs server/index.ts",
    "web": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/vite/bin/vite.js build",
    "demo": "pnpm --filter @tripassist/demo dev",
    "demo:build": "pnpm --filter @tripassist/demo build",
    "demo:preview": "pnpm --filter @tripassist/demo preview",
    "start": "node node_modules/tsx/dist/cli.mjs server/index.ts",
    "smoke": "node node_modules/tsx/dist/cli.mjs scripts/smoke.ts",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:watch": "node node_modules/vitest/vitest.mjs",
    "test:coverage": "node node_modules/vitest/vitest.mjs run --coverage",
    "typecheck": "node node_modules/typescript/bin/tsc -p tsconfig.server.json --noEmit && node node_modules/typescript/bin/tsc -p tsconfig.web.json --noEmit && pnpm --filter @tripassist/demo typecheck",
    "lint": "node node_modules/eslint/bin/eslint.js . && pnpm --filter @tripassist/demo lint",
    "lint:fix": "node node_modules/eslint/bin/eslint.js . --fix && pnpm --filter @tripassist/demo lint:fix",
    "format": "node node_modules/prettier/bin/prettier.cjs --write .",
    "format:check": "node node_modules/prettier/bin/prettier.cjs --check .",
    "prepare": "node node_modules/lefthook/bin/index.js install",
    "pw:install": "node node_modules/playwright/cli.js install chromium"
  },
  "dependencies": {
    "express": "^4.19.2",
    "lucide-react": "^1.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vapi-ai/mcp-docs-server": "^0.1.9",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.0",
    "vitest": "^3.2.6"
  }
}
