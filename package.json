{
  "name": "tripassist",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "description": "TripAssist — static demo showcase: one Vite app with two entry points (story landing page + operator dashboard) → GitHub Pages. The functional MVP lives on the `mvp` branch.",
  "comment": "Single app, no workspace. Scripts call `node node_modules/<pkg>/...` directly, never npx/pnpm-exec/bare bins, because the repo path can contain a ':' that corrupts the .bin PATH shim. `pnpm` itself (corepack-managed) is safe to call.",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "typecheck": "node node_modules/typescript/bin/tsc -p tsconfig.json --noEmit && node node_modules/typescript/bin/tsc -p tsconfig.node.json --noEmit",
    "lint": "node node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node node_modules/eslint/bin/eslint.js . --fix",
    "format": "node node_modules/prettier/bin/prettier.cjs --write .",
    "format:check": "node node_modules/prettier/bin/prettier.cjs --check .",
    "prepare": "node node_modules/lefthook/bin/index.js install",
    "assets:voices": "node node_modules/tsx/dist/cli.mjs tooling/demo/generate-voices.ts",
    "assets:faces": "node node_modules/tsx/dist/cli.mjs tooling/demo/generate-faces.ts",
    "assets:clips": "node node_modules/tsx/dist/cli.mjs tooling/demo/generate-clips.ts"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "howler": "^2.2.4",
    "lucide-react": "^1.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/howler": "^2.2.11",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "lefthook": "^2.1.9",
    "lighthouse": "^13.4.0",
    "playwright-core": "^1.61.1",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.0"
  }
}
